# MCP Runtime Policy Gateway local configuration example.
# Do not commit real secrets or production target credentials.

GATEWAY_DB_PATH=.data/gateway.sqlite
GATEWAY_POLICY_PATH=examples/policies/default-deny.yaml

# Stdio MVP identity is one configured principal, not authenticated per-user identity.
GATEWAY_TENANT_ID=default-tenant
GATEWAY_CLIENT_ID=local-client
GATEWAY_ACTOR_ID=local-operator

# Default client surface hides operator-only control tools. Use operator only for
# trusted config/review sessions.
GATEWAY_TOOL_SURFACE_MODE=client

# Replace for any non-demo use. Used for tenant-scoped HMAC policy/argument/result evidence.
GATEWAY_HMAC_SECRET=replace-with-a-long-random-secret

# Comma-separated absolute executables for stdio target registration.
GATEWAY_EXEC_ALLOWLIST=/usr/bin/node
GATEWAY_DEV_MODE=false
GATEWAY_ALLOW_UNLISTED_EXECUTABLES=false

# Stdio targets inherit only these non-secret environment keys by default.
GATEWAY_STDIO_ENV_KEYS=PATH,SystemRoot,WINDIR,ComSpec

# HTTP target egress guard. Keep private egress disabled outside local tests.
GATEWAY_EGRESS_SCHEMES=https
GATEWAY_EGRESS_HOSTS=
GATEWAY_EGRESS_ALLOW_PRIVATE=false
